# Required for the live microphone demo.
DEEPGRAM_API_KEY=

# Optional: receive voice lifecycle webhooks while testing locally.
VOICE_DEMO_WEBHOOK_URL=
VOICE_DEMO_TELEPHONY_WEBHOOK_SECRET=

# Optional provider keys for local experimentation.
ASSEMBLYAI_API_KEY=
ASSEMBLYAI_SPEECH_MODEL=u3-rt-pro
ELEVENLABS_API_KEY=
OPENAI_API_KEY=

# Optional STT latency budgets for provider routing.
VOICE_DEEPGRAM_STT_TIMEOUT_MS=5000
VOICE_ASSEMBLYAI_STT_TIMEOUT_MS=6000
