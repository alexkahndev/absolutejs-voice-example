# Required for the live microphone demo.
DEEPGRAM_API_KEY=

# Optional: receive voice lifecycle webhooks while testing locally.
VOICE_DEMO_WEBHOOK_URL=
VOICE_DEMO_PUBLIC_BASE_URL=
VOICE_DEMO_TELEPHONY_WEBHOOK_SECRET=

# Optional carrier matrix signing checks.
# Use local for demos without a public HTTPS/WSS tunnel. Use production to
# require carrier-grade public URLs and webhook signing credentials.
VOICE_DEMO_CARRIER_READINESS=local
TELNYX_PUBLIC_KEY=
PLIVO_AUTH_TOKEN=

# Optional readiness smoke tuning for slow local machines or busy agent runs.
VOICE_READINESS_SERVER_WAIT_MS=30000
VOICE_READINESS_SERVER_POLL_MS=500
VOICE_READINESS_SERVER_OUTPUT_LINES=80
VOICE_READINESS_SMOKE_TIMEOUT_MS=8000

# Optional delivery sink descriptor mode shown in ops/readiness.
# The demo still uses local file stores unless you swap the worker/store layer.
VOICE_DELIVERY_SINK=file
# VOICE_DELIVERY_WEBHOOK_URL=https://example.test/voice-delivery
# VOICE_DELIVERY_S3_BUCKET=s3://absolutejs-voice-demo-deliveries/voice-demo

# Optional observability export archive destination.
# File delivery is always enabled at .voice-runtime/observability-exports.
# Set these to also ship verified manifests, artifact indexes, and artifacts to Bun S3.
# VOICE_OBSERVABILITY_EXPORT_S3_BUCKET=absolutejs-voice-demo-evidence
# VOICE_OBSERVABILITY_EXPORT_S3_PREFIX=absolutejs-voice-demo
# Set these to also persist export manifests and artifact indexes to buyer-owned databases.
# VOICE_OBSERVABILITY_EXPORT_SQLITE_PATH=.voice-runtime/observability-exports.sqlite
# VOICE_OBSERVABILITY_EXPORT_SQLITE_TABLE=voice_observability_exports
# VOICE_OBSERVABILITY_EXPORT_POSTGRES_URL=postgres://user:password@localhost:5432/voice
# VOICE_OBSERVABILITY_EXPORT_POSTGRES_SCHEMA=voice
# VOICE_OBSERVABILITY_EXPORT_POSTGRES_TABLE=observability_exports

# Optional provider keys for local experimentation.
ASSEMBLYAI_API_KEY=
ASSEMBLYAI_SPEECH_MODEL=u3-rt-pro
ELEVENLABS_API_KEY=
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin

# Optional STT latency budgets for provider routing.
VOICE_DEEPGRAM_STT_TIMEOUT_MS=5000
VOICE_ASSEMBLYAI_STT_TIMEOUT_MS=6000
